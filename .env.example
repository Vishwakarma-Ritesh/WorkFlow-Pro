# Application target
TEST_ENV=staging
DEFAULT_TENANT=company1
DEFAULT_ROLE=admin

# Tenant base URLs
WORKFLOWPRO_COMPANY1_BASE_URL=https://company1.workflowpro.com
WORKFLOWPRO_COMPANY2_BASE_URL=https://company2.workflowpro.com
WORKFLOWPRO_API_BASE_URL=https://api.workflowpro.com

# Test users. Store real values in your secret manager or local .env only.
WORKFLOWPRO_COMPANY1_ADMIN_EMAIL=
WORKFLOWPRO_COMPANY1_ADMIN_PASSWORD=
WORKFLOWPRO_COMPANY1_MANAGER_EMAIL=
WORKFLOWPRO_COMPANY1_MANAGER_PASSWORD=
WORKFLOWPRO_COMPANY1_EMPLOYEE_EMAIL=
WORKFLOWPRO_COMPANY1_EMPLOYEE_PASSWORD=
WORKFLOWPRO_COMPANY2_ADMIN_EMAIL=
WORKFLOWPRO_COMPANY2_ADMIN_PASSWORD=
WORKFLOWPRO_COMPANY2_MANAGER_EMAIL=
WORKFLOWPRO_COMPANY2_MANAGER_PASSWORD=
WORKFLOWPRO_COMPANY2_EMPLOYEE_EMAIL=
WORKFLOWPRO_COMPANY2_EMPLOYEE_PASSWORD=

# Optional API tokens. If omitted, auth_client can request one from /api/v1/auth/login.
WORKFLOWPRO_COMPANY1_ADMIN_TOKEN=
WORKFLOWPRO_COMPANY2_ADMIN_TOKEN=

# Optional 2FA test bypass or generated OTP.
WORKFLOWPRO_TEST_OTP=
WORKFLOWPRO_2FA_BYPASS_TOKEN=

# BrowserStack
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BROWSERSTACK_BUILD_NAME=workflowpro-local
BROWSERSTACK_PROJECT_NAME=WorkFlow Pro QA Automation
BROWSERSTACK_LOCAL=false
BROWSERSTACK_LOCAL_IDENTIFIER=
